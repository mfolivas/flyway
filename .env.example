# Copy this file to .env before running `docker compose up`.
# All values below are safe defaults for local development only.
# Never commit a real .env file with production credentials.

# PostgreSQL container configuration
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=trading_password
POSTGRES_DB=trading

# Connection string used by Flyway and the FastAPI service
# Hostname `postgres` matches the docker-compose service name.
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_URL=postgresql+psycopg2://trading_user:trading_password@postgres:5432/trading

# Flyway-specific configuration
FLYWAY_URL=jdbc:postgresql://postgres:5432/trading
FLYWAY_USER=trading_user
FLYWAY_PASSWORD=trading_password

# FastAPI service
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
